<section id="sobre-mi" class="container py-5 my-5 reveal">

    <div class="row align-items-center modern-box">
        <div class="col-md-6 text-white">
            <h2 class="title">Sobre Mí</h2 >
            <p class="subtitle">
                Formación profesional en Ing. en Sistemas Comptacionales, me gusta construir software y entender cómo funciona la tecnología 
                desde el código hasta el hardware. Mi enfoque combina el uso de las 
                tecnologías del entorno .NET como WindowsForms, Blazor, Aplicaciones Android en .NET MAUI y
                Apliaciones de Consola en C#. 
            </p>
        </div>
        <div class="col-md-6 text-center">
            <div class="p-5 rounded foto">
                <img src="images\usuario.png" />
            </div>
        </div>
    </div>
</section>

<section id="proyectos" class="py-5 my-5 reveal">
    <div class="container modern-box">
        <h2 class="text-center display-5 fw-bold mb-5 text-white">Mis Proyectos</h2>
        <div class="row">
    @foreach (var project in MyProjects)
    {
        <div class="col-md-4 mb-4 ">
            <div class="card h-100 shadow-sm project-card">
                <img src="@project.ImageUrl" class="card-img-top" alt="@project.Title">
                <a href="@project.Link" target="_blank" class="stretched-link"></a>
                <div class="card-body text-center navbar ">
                    <h5 class="card-title fw-bold text-white">@project.Title</h5>
                    <p class="card-text small text-white">@project.Description</p>

                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-3">
                        @foreach (var tech in project.Technologies)
                        {
                            <span class="tech-badge">@tech</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    </div>

    </div>
</section>

<section id="certificados" class="reveal">
