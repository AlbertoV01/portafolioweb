                <button type="button" data-bs-target="#carouselCertificados" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#carouselCertificados" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>

            <div class="carousel-inner rounded-4">
                
                <div class="carousel-item active" data-bs-interval="5000">
                    <a href="https://cert.efset.org/c2KqVj" target="_blank">
                    <div class="certificate-wrapper">
                       <img src="images/cenglish.png" class="d-block w-100 certificate-img" > 
                    </div>
                    </a>
                </div>

                <div class="carousel-item" data-bs-interval="5000">
                    <a href="https://udemy-certificate.s3.amazonaws.com/pdf/UC-41fb9792-e368-45fe-87b6-e1ac2bef7b7b.pdf" target="_blank">
                    <div class="certificate-wrapper">
                       <img src="images/ccsharp.jpg" class="d-block w-100 certificate-img" > 
                        
                    </div> 
                    </a>
                </div>

                <div class="carousel-item" data-bs-interval="5000">
                    <a href="https://udemy-certificate.s3.amazonaws.com/pdf/UC-d19998b4-e9d5-4104-9091-a050ec360f82.pdf" target="_blank">
                    <div class="certificate-wrapper">
                       <img src="images/csql.jpg" class="d-block w-100 certificate-img" alt="Certificado SQL Server"> 
                    </div>
                    </a>
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#carouselCertificados" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselCertificados" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Siguiente</span>
            </button>
        </div>
    </div>
</section>


<section id="contacto" class="py-5 reveal bg-gray-700 rounded">
    <div class="container contenedor">
        <div class="row justify-content-center">
            <div class="col-md-6 shadow-lg p-4 rounded-4 modern-box">
                <h2 class="text-center mb-4 fw-bold">¡Hablemos!</h2>
                <p class="text-center mb-4 text-white">¿Tienes una idea de negocio o necesitas una reparación técnica? Escríbeme.</p>

                <EditForm Model="@contact" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre</label>
                        <InputText @bind-Value="contact.Name" class="form-control" placeholder="Tu nombre" />
                        <ValidationMessage For="@(() => contact.Name)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correo Electrónico</label>
                        <InputText @bind-Value="contact.Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <ValidationMessage For="@(() => contact.Email)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mensaje</label>
                        <InputTextArea @bind-Value="contact.Message" class="form-control" rows="4" placeholder="¿En qué puedo ayudarte?" />
                        <ValidationMessage For="@(() => contact.Message)" class="text-danger small" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm mt-3">
                        Enviar Mensaje
                    </button>
                </EditForm>

                @if (formEnviado)
                {
                    <div class="alert alert-success mt-4 text-center">
                        ✅ ¡Gracias! Me pondré en contacto contigo pronto.
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<footer class="bg-dark text-white text-center py-4 mt-5">
    <div class="container">
        <p class="mb-0">© 2026 - Desarrollador .NET</p>
        <div class="mt-2">
            <a href="https://github.com/AlbertoV01" class="text-white me-3 text-decoration-none">GitHub</a>
            <a href="https://www.linkedin.com/in/alberto-valenzuela-rivera-2a4b86225/" class="text-white me-3 text-decoration-none">LinkedIn</a>
            
        </div>
    </div>
</footer>

